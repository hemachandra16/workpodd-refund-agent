# ============================================================
# WORPODD Refund Agent — environment template
# Copy to .env and fill in. NEVER commit .env
# ============================================================

# ---- Groq (single key powers LLM + STT + TTS) ----
GROQ_API_KEY=gsk_your_key_here
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_TTS_MODEL=canopylabs/orpheus-v1-english
GROQ_TTS_VOICE=troy

# ---- Server ----
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
ENVIRONMENT=development
# In production set to https://your-frontend.example.com
FRONTEND_ORIGIN=http://localhost:3000

# ---- Database ----
DATABASE_URL=sqlite:///./data/worpodd.db

# ---- Admin auth ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SESSION_SECRET=change_me_to_a_long_random_string
ADMIN_USERNAME=admin
# bcrypt hash of the admin password. Generate with:
#   python -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpass'))"
ADMIN_PASSWORD_HASH=$2b$12$replace_with_real_bcrypt_hash

# ---- Rate limiting (requests per window per IP/session) ----
RATE_LIMIT_CHAT=30/minute
RATE_LIMIT_VOICE=20/minute
RATE_LIMIT_ADMIN=120/minute

# ---- Safety ----
MAX_MESSAGE_CHARS=1000
MAX_AGENT_STEPS=8
